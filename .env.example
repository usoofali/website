# ============================================================
#  .env.example — copy to .env on each server and customise.
#  The .env file is git-ignored; this file IS committed.
# ============================================================

# Environment
APP_ENV=production

# ── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# ── Theme ──────────────────────────────────────────────────
# Each environment sets its own palette here.
# No branch, no recompile — just change these values and
# upload a matching favicon file to assets/images/.
#
# --- Environment A example (Blue / Teal) ---
# THEME_PRIMARY=#4b6cb7
# THEME_SECONDARY=#182848
# THEME_ACCENT=#00d2ff
# THEME_BG_FROM=#f5f7fa
# THEME_BG_TO=#c3cfe2
# THEME_GLASS_BG=rgba(255,255,255,0.4)
# THEME_GLASS_BORDER=rgba(255,255,255,0.6)
# THEME_FAVICON=favicon.ico
# THEME_SLIDES_DIR=assets/images/slides
#
# --- Environment B example (Forest Green / Gold) -----------
# THEME_PRIMARY=#1b6b3a
# THEME_SECONDARY=#0d3320
# THEME_ACCENT=#f0a500
# THEME_BG_FROM=#e8f5e9
# THEME_BG_TO=#a5d6b7
# THEME_GLASS_BG=rgba(232,245,233,0.45)
# THEME_GLASS_BORDER=rgba(165,214,167,0.6)
# THEME_FAVICON=favicon-b.ico
# THEME_SLIDES_DIR=assets/images/slides-b

THEME_PRIMARY=#4b6cb7
THEME_SECONDARY=#182848
THEME_ACCENT=#00d2ff
THEME_BG_FROM=#f5f7fa
THEME_BG_TO=#c3cfe2
THEME_GLASS_BG=rgba(255,255,255,0.4)
THEME_GLASS_BORDER=rgba(255,255,255,0.6)
THEME_FAVICON=favicon.ico
THEME_SLIDES_DIR=assets/images/slides